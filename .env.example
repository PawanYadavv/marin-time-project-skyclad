# Environment
PORT=3000
NODE_ENV=development

# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=your-api-key-here

# Database
DATABASE_PATH=./data/smde.db

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# LLM Timeout (ms)
LLM_TIMEOUT_MS=30000

# Upload
MAX_FILE_SIZE_MB=10
